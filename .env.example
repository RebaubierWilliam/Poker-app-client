# Base URL used by the fetch client at runtime.
# Leave empty to use relative paths via the Vite dev proxy defined in vite.config.ts.
VITE_API_BASE_URL=

# Target used by the Vite dev server proxy when VITE_API_BASE_URL is empty.
# Default: https://poker-blind-timer.fly.dev
VITE_API_PROXY_TARGET=https://poker-blind-timer.fly.dev
